# Игнорируем всё...
*

# ...кроме гитигнора, README, конфигов в корне и скриптов в src/
!.gitignore
!README.md
!/docker-compose.yml
!/tags.json

!/src/
!/src/*.py
!/src/*.bat

# Примеры для README
!/examples/
!/examples/*.jpg

# Пустая папка для входящих фотографий: сами фото не коммитим
!/input/
!/input/.gitkeep

# Служебное
*.log
__pycache__/
